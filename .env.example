# Copy this file to `.env` and fill in the key(s) for whichever provider(s) you
# want to use. `.env` is gitignored, so your keys are never committed.
# Only the key for the model you actually run needs to be set.

# OpenAI  -> models like: gpt-5.1, gpt-4o, o3
OPENAI_API_KEY=

# Anthropic -> models like: claude-opus-4-5, claude-sonnet-4-5
ANTHROPIC_API_KEY=

# Google -> models like: gemini-2.5-pro, gemini-2.5-flash
GEMINI_API_KEY=

# --- Optional OpenAI-compatible providers (use --model provider:model) ---
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
